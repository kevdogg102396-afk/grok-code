{
  "name": "grok-code",
  "version": "2.0.0",
  "description": "Autonomous AI coding agent powered by xAI's Grok",
  "type": "module",
  "bin": {
    "grok-code": "./bin/grok-code.ts"
  },
  "scripts": {
    "start": "bun run bin/grok-code.ts",
    "build": "bun build bin/grok-code.ts --compile --outfile dist/grok-code",
    "dev": "bun run --watch bin/grok-code.ts"
  },
  "dependencies": {
    "ink": "^5.1.0",
    "react": "^18.3.1",
    "ink-text-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "figlet": "^1.8.0",
    "gradient-string": "^3.0.0",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/figlet": "^1.7.0",
    "@types/react": "^18.3.0",
    "react-devtools-core": "^7.0.1",
    "typescript": "^5.7.0"
  },
  "author": "ClawdWorks",
  "license": "Apache-2.0"
}
